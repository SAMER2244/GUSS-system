# ============================================================
# ملف نموذج متغيرات البيئة للباك اند (FastAPI)
# انسخ هذا الملف باسم .env واملأ القيم الحقيقية
# ============================================================

# مفتاح Gemini API Key لتوليد التقارير
GEMINI_API_KEY=your-gemini-api-key-here

# ── Supabase Database ───────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# ── CORS Settings ───────────────────────────────────────────
# رابط واجهة المستخدم المستضافة على Netlify لتمكين CORS (لا تضع * للأمان)
# مثال: ALLOWED_ORIGIN=https://guss-reports.netlify.app
ALLOWED_ORIGIN=https://your-netlify-app.netlify.app
